{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills Manager",
  "version": "0.1.0",
  "identifier": "local.skills-manager.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Skills Manager",
        "url": "index.html?view=panel",
        "width": 380,
        "height": 560,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Skills Manager Settings",
        "url": "index.html?view=settings",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
